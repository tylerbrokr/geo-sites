# --- Supabase (the same project this Lovable repo points to) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Hostname routing ---
# Wildcard parent for managed subdomains. Anything else is treated as a custom domain.
NEXT_PUBLIC_SITES_PARENT_DOMAIN=sites.geoemployee.com

# --- Cache revalidation (Phase 2) ---
# Shared secret the Supabase edge function (publish-post) sends in
# x-revalidate-secret to trigger on-demand revalidation.
REVALIDATE_SECRET=replace-me-in-cloudflare-pages
